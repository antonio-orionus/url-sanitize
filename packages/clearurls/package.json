{
  "name": "@url-sanitize/clearurls",
  "version": "0.1.1",
  "description": "ClearURLs-compatible rule catalog and adapter for @url-sanitize/core. Daily-synced from upstream.",
  "license": "LGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./raw": {
      "types": "./dist/raw.d.ts",
      "import": "./dist/raw.js"
    }
  },
  "files": ["dist", "data", "NOTICE"],
  "scripts": {
    "build": "tsup src/index.ts src/raw.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/raw.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@url-sanitize/core": "workspace:*"
  },
  "keywords": ["clearurls", "clearurls-ts", "clearurls-typescript", "url", "tracking", "privacy"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antonio-orionus/url-sanitize.git",
    "directory": "packages/clearurls"
  },
  "sideEffects": false
}
