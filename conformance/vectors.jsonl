{"id":"unchanged-clean","input":"https://example.com/article","note":"clean URL is unchanged","expected":{"kind":"unchanged","url":"https://example.com/article"}}
{"id":"unchanged-with-kept-params","input":"https://example.com/search?q=hello&page=2","note":"non-tracking params kept","expected":{"kind":"unchanged","url":"https://example.com/search?q=hello&page=2"}}
{"id":"unchanged-empty","input":"","note":"empty input","expected":{"kind":"unchanged","url":""}}
{"id":"unchanged-malformed","input":"not a url","note":"P4: malformed input returns unchanged verbatim","expected":{"kind":"unchanged","url":"not a url"}}
{"id":"unchanged-malformed-scheme","input":"htps:/x","note":"no scheme separator","expected":{"kind":"unchanged","url":"htps:/x"}}
{"id":"strip-utm-basic","input":"https://example.com/article?utm_source=newsletter&utm_medium=email&id=123","note":"globalRules utm_* via strip-param","expected":{"kind":"cleaned","url":"https://example.com/article?id=123","strippedParamsContains":["utm_medium","utm_source"],"matchedProviders":["globalRules"]}}
{"id":"strip-fbclid","input":"https://example.com/?fbclid=ABCDEF","note":"globalRules fbclid","expected":{"kind":"cleaned","url":"https://example.com/","strippedParamsContains":["fbclid"],"matchedProviders":["globalRules"]}}
{"id":"strip-gclid","input":"https://example.com/path?gclid=xyz&keep=1","note":"globalRules gclid","expected":{"kind":"cleaned","url":"https://example.com/path?keep=1","strippedParamsContains":["gclid"],"matchedProviders":["globalRules"]}}
{"id":"strip-multiple-trackers","input":"https://news.example.com/article?utm_source=tw&fbclid=ABC&mkt_tok=zzz&id=99","note":"utm + fbclid + mkt_tok","expected":{"kind":"cleaned","url":"https://news.example.com/article?id=99","strippedParamsContains":["fbclid","mkt_tok","utm_source"],"matchedProviders":["globalRules"]}}
{"id":"strip-no-eq-param","input":"https://example.com/?utm_source&kept","note":"param without value, just name","expected":{"kind":"cleaned","url":"https://example.com/?kept","strippedParamsContains":["utm_source"],"matchedProviders":["globalRules"]}}
{"id":"strip-fragment-params","input":"https://example.com/#utm_source=hash&keep=ok","note":"P8: tracker in fragment-as-query","expected":{"kind":"cleaned","url":"https://example.com/#keep=ok","strippedParamsContains":["utm_source"],"matchedProviders":["globalRules"]}}
{"id":"strip-percent-encoded","input":"https://example.com/?q=hello%20world&utm_source=x","note":"P9: percent-encoded kept value preserved","expected":{"kind":"cleaned","url":"https://example.com/?q=hello%20world","strippedParamsContains":["utm_source"],"matchedProviders":["globalRules"]}}
{"id":"strip-empty-after","input":"https://example.com/path?utm_source=x&fbclid=y","note":"all params were trackers — query removed","expected":{"kind":"cleaned","url":"https://example.com/path","strippedParamsContains":["fbclid","utm_source"],"matchedProviders":["globalRules"]}}
{"id":"youtube-strip-si","input":"https://www.youtube.com/watch?v=dQw4w9WgXcQ&si=ABCDEFG&feature=share","note":"youtube si tracker","expected":{"kind":"cleaned","url":"https://www.youtube.com/watch?v=dQw4w9WgXcQ","strippedParamsContains":["feature","si"],"matchedProviders":["youtube"]}}
{"id":"amazon-ref-raw-replace","input":"https://www.amazon.com/dp/B08N5WRWNW/ref=cm_sw_r_cp_x","note":"amazon /ref=... raw-replace path strip","expected":{"kind":"cleaned","url":"https://www.amazon.com/dp/B08N5WRWNW","strippedParamsContains":[],"matchedProviders":["amazon"]}}
{"id":"amazon-tag-kept-by-default","input":"https://www.amazon.com/dp/B0?tag=affiliate-20","note":"referralMarketing tag is kept unless --strip-referral","expected":{"kind":"unchanged","url":"https://www.amazon.com/dp/B0?tag=affiliate-20"}}
{"id":"amazon-tag-stripped-with-opt","input":"https://www.amazon.com/dp/B0?tag=affiliate-20","options":{"stripReferralMarketing":true},"note":"opt-in: strip referral tag","expected":{"kind":"cleaned","url":"https://www.amazon.com/dp/B0","strippedParamsContains":["tag"],"matchedProviders":["amazon"]}}
{"id":"google-redirect-unwrap","input":"https://www.google.com/url?sa=t&q=https%3A%2F%2Fexample.com%2Ftarget","note":"google /url?q= unwraps","expected":{"kind":"redirected","url":"https://example.com/target","viaProvider":"google"}}
{"id":"google-redirect-disabled","input":"https://www.google.com/url?sa=t&q=https%3A%2F%2Fexample.com%2Ftarget","options":{"unwrapRedirects":false},"note":"--no-unwrap-redirects leaves it","expected":{"kind":"cleaned","url":"https://www.google.com/url?q=https%3A%2F%2Fexample.com%2Ftarget","strippedParamsContains":["sa"],"matchedProviders":["google"]}}
{"id":"youtube-redirect-unwrap","input":"https://www.youtube.com/redirect?q=https%3A%2F%2Fexample.org%2Fdest&v=x","note":"youtube /redirect?q= unwraps","expected":{"kind":"redirected","url":"https://example.org/dest","viaProvider":"youtube"}}
{"id":"facebook-l-php-unwrap","input":"https://l.facebook.com/l.php?u=https%3A%2F%2Fexample.com%2Fpage&h=hash","note":"l.facebook.com l.php?u= unwraps","expected":{"kind":"redirected","url":"https://example.com/page","viaProvider":"facebook"}}
{"id":"idempotent-utm","input":"https://example.com/?utm_source=a&keep=1","note":"P1: idempotence — second pass is no-op","expected":{"kind":"cleaned","url":"https://example.com/?keep=1","strippedParamsContains":["utm_source"],"matchedProviders":["globalRules"]}}
{"id":"idempotent-already-clean","input":"https://example.com/article?keep=1","note":"P1: clean URL idempotent","expected":{"kind":"unchanged","url":"https://example.com/article?keep=1"}}
{"id":"host-integrity","input":"https://news.example.com/path?utm_campaign=x","note":"P2: cleaning never changes host","expected":{"kind":"cleaned","url":"https://news.example.com/path","strippedParamsContains":["utm_campaign"],"matchedProviders":["globalRules"]}}
{"id":"path-integrity-strip","input":"https://example.com/some/deep/path?utm_source=x","note":"P3: strip-only never touches path","expected":{"kind":"cleaned","url":"https://example.com/some/deep/path","strippedParamsContains":["utm_source"],"matchedProviders":["globalRules"]}}
{"id":"option-monotonic-default","input":"https://www.amazon.com/dp/B0?utm_source=x&tag=aff","note":"P5 baseline","expected":{"kind":"cleaned","url":"https://www.amazon.com/dp/B0?tag=aff","strippedParamsContains":["utm_source"],"matchedProviders":["globalRules"]}}
{"id":"option-monotonic-referral","input":"https://www.amazon.com/dp/B0?utm_source=x&tag=aff","options":{"stripReferralMarketing":true},"note":"P5 superset: adds referral strip","expected":{"kind":"cleaned","url":"https://www.amazon.com/dp/B0","strippedParamsContains":["tag","utm_source"],"matchedProviders":["amazon","globalRules"]}}
{"id":"reddit-redirect","input":"https://out.reddit.com/t3_xxx?url=https%3A%2F%2Fexample.com%2Fx&token=abc","note":"out.reddit.com unwraps","expected":{"kind":"redirected","url":"https://example.com/x","viaProvider":"reddit"}}
{"id":"twitter-strip-s-t","input":"https://twitter.com/user/status/123?s=20&t=abcdef","note":"twitter s + t params","expected":{"kind":"cleaned","url":"https://twitter.com/user/status/123","strippedParamsContains":["s","t"],"matchedProviders":["twitter"]}}
{"id":"non-http-scheme","input":"ftp://files.example.com/x","note":"ftp URL — most rules don't fire","expected":{"kind":"unchanged","url":"ftp://files.example.com/x"}}
{"id":"weird-port","input":"https://example.com:8443/?utm_source=x","note":"explicit port preserved","expected":{"kind":"cleaned","url":"https://example.com:8443/","strippedParamsContains":["utm_source"],"matchedProviders":["globalRules"]}}
{"id":"trailing-slash","input":"https://example.com","note":"bare host gets trailing slash normalized","expected":{"kind":"cleaned","url":"https://example.com/","strippedParamsContains":[],"matchedProviders":[]}}
